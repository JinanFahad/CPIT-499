# نسخي هذا الملف باسم .env وعبّي القيم الحقيقية
# ملاحظة: ملف .env مستبعد من Git (محمي في .gitignore) — لا ترفعيه أبداً

# ── OpenAI ──
# مفتاح OpenAI (من https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP (إعدادات إرسال الإيميلات) ──
# عشان ميزة "إرسال على الإيميل" تشتغل
# Gmail: لازم تستخدمي App Password مو كلمة السر العادية
# (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
